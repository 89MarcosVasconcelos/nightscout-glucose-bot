# ── Nightscout ────────────────────────────────────────────────────────────────
NIGHTSCOUT_URL=https://glicose.marcosvasconcelos.dev.br
NIGHTSCOUT_API_SECRET=seu_api_secret_aqui
# NIGHTSCOUT_TOKEN=       # alternativa ao API_SECRET, se usar token de acesso

# ── Evolution API ─────────────────────────────────────────────────────────────
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=sua_chave_api_evolution_aqui
EVOLUTION_INSTANCE=caquinho-bot

# ── Limites de glicose (mg/dL) ────────────────────────────────────────────────
GLUCOSE_LOW=70
GLUCOSE_HIGH=180

# ── Comportamento ─────────────────────────────────────────────────────────────
POLL_INTERVAL=300     # segundos entre cada consulta (padrão: 5 minutos)
ALERT_COOLDOWN=1800   # segundos de cooldown entre alertas do mesmo tipo (padrão: 30 min)
WEBHOOK_PORT=8080

# ── Arquivo de contatos ───────────────────────────────────────────────────────
CONTACTS_FILE=/data/contacts.json
